import umap
import matplotlib.patches as mpatches

# ── Figure 4: UMAP of Input Feature Space by Site ─────────────────────────────

# Use only numerical features for a clean feature-space view
num_cols_clean = ['SRadiation', 'Prec', 'WD', 'WS', 'AT', 'WC', 'ST', 'RH ', 'pH']
X_num = StandardScaler().fit_transform(df[num_cols_clean].values)

# Fit UMAP
reducer = umap.UMAP(n_components=2, n_neighbors=15, min_dist=0.1, random_state=42)
embedding = reducer.fit_transform(X_num)

# Site labels and colors
sites      = df['Site Name'].values
site_names = ['Agron Farm', 'LP Mineral', 'Allstar #1']
colors     = ['#1f77b4', '#ff7f0e', '#2ca02c']   # blue, orange, green
site_color_map = dict(zip(site_names, colors))
point_colors   = [site_color_map[s] for s in sites]

# ── Panel 1: colored by site  |  Panel 2: colored by NO3 value ──────────────
fig, axes = plt.subplots(1, 2, figsize=(14, 6))

# Left panel — site labels
ax = axes[0]
for site, col in zip(site_names, colors):
    mask = sites == site
    ax.scatter(embedding[mask, 0], embedding[mask, 1],
               c=col, s=30, alpha=0.75, label=site, edgecolors='none')
ax.set_title('UMAP — Feature Space by Site', fontsize=13, fontweight='bold')
ax.set_xlabel('UMAP 1', fontsize=11)
ax.set_ylabel('UMAP 2', fontsize=11)
ax.legend(title='Site', fontsize=10, title_fontsize=10)
ax.tick_params(labelsize=9)

# Right panel — NO3 value as continuous color
ax = axes[1]
sc = ax.scatter(embedding[:, 0], embedding[:, 1],
                c=y, cmap='YlOrRd', s=30, alpha=0.85, edgecolors='none')
cbar = plt.colorbar(sc, ax=ax)
cbar.set_label('NO3', fontsize=11)
ax.set_title('UMAP — Feature Space colored by NO3', fontsize=13, fontweight='bold')
ax.set_xlabel('UMAP 1', fontsize=11)
ax.set_ylabel('UMAP 2', fontsize=11)
ax.tick_params(labelsize=9)

plt.tight_layout()
plt.savefig('fig4_umap.png', dpi=150, bbox_inches='tight')
plt.show()
files.download('fig4_umap.png')
print('UMAP figure saved.')

# ── Figure: t-SNE of Input Feature Space — All 6 Sites ───────────────────────
from sklearn.manifold import TSNE

# Numerical features only
num_cols_clean = ['SRadiation', 'Prec', 'WD', 'WS', 'AT', 'WC', 'ST', 'RH ', 'pH']
df_tsne = df.copy()
df_tsne[num_cols_clean] = df_tsne[num_cols_clean].apply(pd.to_numeric, errors='coerce')
df_tsne = df_tsne.dropna(subset=num_cols_clean + ['NO3']).copy()

X_num = StandardScaler().fit_transform(df_tsne[num_cols_clean].values)
y_tsne = df_tsne['NO3'].values
sites  = df_tsne['Site Name'].values

# Fit t-SNE (perplexity should be < n_samples/3; adjust if dataset is small)
n_samples   = len(X_num)
perplexity  = min(30, max(5, n_samples // 4))
tsne = TSNE(n_components=2, perplexity=perplexity, random_state=42,
            n_iter=1000, learning_rate='auto', init='pca')
embedding = tsne.fit_transform(X_num)
print(f't-SNE done. Samples: {n_samples}, Perplexity used: {perplexity}')

# 6 distinct colors for 6 sites
site_names = sorted(df_tsne['Site Name'].unique())
palette    = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd', '#8c564b']
color_map  = dict(zip(site_names, palette[:len(site_names)]))
point_colors = [color_map[s] for s in sites]

