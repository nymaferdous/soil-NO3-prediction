# ── Residuals vs Water Content (WC) ──────────────────────────────────────────
from sklearn.model_selection import train_test_split

# Recover test indices
indices = np.arange(len(X_scaled))
idx_train, idx_test = train_test_split(indices, test_size=0.3, random_state=42)

# Get test data
df_test   = df.iloc[idx_test].reset_index(drop=True)
y_pred_rf = rf_model.predict(X_test)
residuals = y_test - y_pred_rf
wc_test   = pd.to_numeric(df_test['WC'], errors='coerce').values
sites_col = df_test['Site Name'].values

# WC threshold used in physics correction (75th percentile of train)
wc_train_vals = pd.to_numeric(df.iloc[idx_train]['WC'], errors='coerce').values
wc_threshold  = np.nanquantile(wc_train_vals, 0.75)

fig, ax = plt.subplots(figsize=(9, 6))

# Plot by site
for site in sorted(set(sites_col)):
    mask = sites_col == site
    ax.scatter(wc_test[mask], residuals[mask],
               color=color_map.get(site, 'grey'),
               s=40, alpha=0.8, label=site,
               edgecolors='white', linewidths=0.4, zorder=3)

# Zero line
ax.axhline(0, color='black', linestyle='--', lw=1.8,
           label='Zero residual', zorder=2)

# Physics correction threshold
ax.axvline(wc_threshold, color='red', linestyle='--', lw=1.8,
           label=f'Physics threshold (WC={wc_threshold:.2f})', zorder=2)

# Shade high-WC region
ax.axvspan(wc_threshold, wc_test.max() * 1.02,
           alpha=0.07, color='red', label='High-WC regime')

# Trend line (rolling mean)
sort_idx  = np.argsort(wc_test)
wc_sorted = wc_test[sort_idx]
rs_sorted = residuals[sort_idx]
roll_mean = pd.Series(rs_sorted).rolling(15, center=True,
                      min_periods=1).mean().values
ax.plot(wc_sorted, roll_mean, color='black', lw=2.0,
        label='Rolling mean', zorder=4)

ax.set_xlabel('Water Content (WC)', fontsize=12)
ax.set_ylabel('Residual (Observed − Predicted)', fontsize=12)
ax.set_title('Residuals vs Water Content\nValidating Physics-Inspired Correction',
             fontsize=13, fontweight='bold')
ax.legend(fontsize=9, framealpha=0.9, edgecolor='grey')
ax.tick_params(labelsize=10)
ax.grid(alpha=0.3, linestyle='--')
ax.set_facecolor('#fafafa')

plt.tight_layout()
plt.savefig('fig_residuals_vs_WC.png', dpi=150, bbox_inches='tight')
plt.show()
files.download('fig_residuals_vs_WC.png')
print('Done.')

