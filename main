# Step 1: Upload CSV
from google.colab import files
import io
uploaded = files.upload()
csv_filename = list(uploaded.keys())[0]
print(f'Uploaded: {csv_filename}')

# Step 2: Install dependencies
!pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121 -q
!pip install transformers scikit-learn xgboost -q
print('Done.')

# Step 3: Imports
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.ticker as ticker
import torch
from transformers import DistilBertTokenizer, DistilBertModel
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score, mean_squared_error, mean_absolute_error
from sklearn.linear_model import Ridge, LinearRegression
from sklearn.tree import DecisionTreeRegressor
from sklearn.neighbors import KNeighborsRegressor
from sklearn.svm import SVR
from sklearn.neural_network import MLPRegressor
from sklearn.ensemble import RandomForestRegressor
from xgboost import XGBRegressor
print('All imports OK')

# Step 4: Load & filter
df = pd.read_csv(io.BytesIO(uploaded[csv_filename]))
# df = df[(df['Site Name'] == 'Agron Farm') |
#         (df['Site Name'] == 'LP Mineral') |
#         (df['Site Name'] == 'Allstar #1')].copy()
# print(f'Rows after filtering: {len(df)}')

# Step 5: DistilBERT embeddings
df['combined_text'] = df[['Notes']].astype(str).agg(' '.join, axis=1)

tokenizer  = DistilBertTokenizer.from_pretrained('distilbert-base-uncased')
bert_model = DistilBertModel.from_pretrained('distilbert-base-uncased')

def get_bert_embeddings(text_list, batch_size=32):
    embeddings = []
    bert_model.eval()
    with torch.no_grad():
        for i in range(0, len(text_list), batch_size):
            batch = text_list[i:i+batch_size]
            inputs  = tokenizer(batch, padding=True, truncation=True, return_tensors='pt')
            outputs = bert_model(**inputs)
            embeddings.append(outputs.last_hidden_state[:, 0, :].numpy())
    return np.vstack(embeddings)

print('Generating BERT embeddings...')
text_embeddings_raw = get_bert_embeddings(df['combined_text'].tolist())
pca = PCA(n_components=2)
text_embeddings = pca.fit_transform(text_embeddings_raw)
print(f'BERT PCA shape: {text_embeddings.shape}, variance explained: {pca.explained_variance_ratio_.sum():.3f}')

# Step 6: Build feature matrix
num_cols = ['SRadiation', 'Prec', 'WD', 'WS', 'AT', 'WC', 'ST', 'RH ', 'pH']
df = df.dropna(subset=['NO3']).copy()
df[num_cols] = df[num_cols].apply(pd.to_numeric, errors='coerce')
valid_mask = df[num_cols].notna().all(axis=1)
df = df[valid_mask].copy()
text_embeddings = text_embeddings[valid_mask.values]

df_dummies = pd.get_dummies(df[['Crop', 'Treatment', 'Site Name']], drop_first=False)
X_full = np.hstack([df[num_cols].values, df_dummies.values, text_embeddings])
y      = df['NO3'].values

scaler   = StandardScaler()
X_scaled = scaler.fit_transform(X_full)

X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y, test_size=0.3, random_state=42
)
print(f'Train: {len(X_train)}, Test: {len(X_test)}, Features: {X_full.shape[1]}')

# Step 7: Train all models
models = [
    ('Our Model (RF)', RandomForestRegressor(n_estimators=100, random_state=42)),
    ('XGBoost',        XGBRegressor(random_state=42, verbosity=0)),
    ('SVR',            SVR()),
    ('KNN',            KNeighborsRegressor(n_neighbors=5)),
    ('MLP',            MLPRegressor(hidden_layer_sizes=(128, 64), max_iter=500, random_state=42)),
    ('Decision Tree',  DecisionTreeRegressor(random_state=42)),
    ('Linear',         LinearRegression()),
    ('Ridge',          Ridge()),
]

results = {}
for name, mdl in models:
    mdl.fit(X_train, y_train)
    y_pred = mdl.predict(X_test)
    results[name] = {
        'y_pred' : y_pred,
        'r2'     : r2_score(y_test, y_pred),
        'rmse'   : np.sqrt(mean_squared_error(y_test, y_pred)),
        'mae'    : mean_absolute_error(y_test, y_pred),
        'resid'  : np.abs(y_test - y_pred),
    }
    print(f"{name:<22} R²={results[name]['r2']:.4f}  RMSE={results[name]['rmse']:.4f}  MAE={results[name]['mae']:.4f}")



# Step 8: Helper — rolling mean & CI band
def rolling_stats(y_obs, y_pred, window=20):
    idx = np.argsort(y_obs)
    x_s = y_obs[idx]
    y_s = y_pred[idx]
    s   = pd.Series(y_s)
    rm  = s.rolling(window, center=True, min_periods=1).mean().values
    rs  = s.rolling(window, center=True, min_periods=1).std().fillna(0).values
    return x_s, rm, rm - rs, rm + rs

# ── Figure 1: 8-panel Observed vs Predicted ───────────────────────────────────
fig, axes = plt.subplots(2, 4, figsize=(18, 9))
axes = axes.flatten()

all_pred = np.concatenate([results[n]['y_pred'] for n, _ in models])
ax_min   = min(y_test.min(), all_pred.min()) * 0.95
ax_max   = max(y_test.max(), all_pred.max()) * 1.05

for ax, (name, _) in zip(axes, models):
    y_pred = results[name]['y_pred']
    ax.scatter(y_test, y_pred, color='steelblue', alpha=0.6, s=20, zorder=3)
    ax.plot([ax_min, ax_max], [ax_min, ax_max], 'b--', lw=1.2, zorder=2)
    x_s, rm, lo, hi = rolling_stats(y_test, y_pred, window=20)
    ax.plot(x_s, rm, 'r-', lw=1.8, zorder=4)
    ax.fill_between(x_s, lo, hi, color='green', alpha=0.25, zorder=1)
    ax.set_title(name, fontsize=11, fontweight='bold')
    ax.set_xlabel('Observed', fontsize=10)
    ax.set_ylabel('Predicted', fontsize=10)
    ax.set_xlim(ax_min, ax_max)
    ax.set_ylim(ax_min, ax_max)
    ax.tick_params(labelsize=8)

plt.suptitle('Observed vs Predicted NO3 — Model Comparison', fontsize=14, fontweight='bold', y=1.01)
plt.tight_layout()
plt.savefig('fig1_obs_vs_pred.png', dpi=150, bbox_inches='tight')
plt.show()
files.download('fig1_obs_vs_pred.png')

# ── Figure 2: Grouped Bar Chart — RMSE & MAE (no R²) ─────────────────────────
model_names = [n for n, _ in models]
rmse_vals   = [results[n]['rmse'] for n in model_names]
mae_vals    = [results[n]['mae']  for n in model_names]

x     = np.arange(len(model_names))
width = 0.35

fig, ax = plt.subplots(figsize=(12, 5))
bars1 = ax.bar(x - width/2, rmse_vals, width, label='RMSE', color='#FF7F0E')
bars2 = ax.bar(x + width/2, mae_vals,  width, label='MAE',  color='#2CA02C')

ax.set_xlabel('Model', fontsize=12)
ax.set_ylabel('Metric Value', fontsize=12)
ax.set_title('Model Comparison — RMSE & MAE', fontsize=13)
ax.set_xticks(x)
ax.set_xticklabels(model_names, rotation=20, ha='right', fontsize=10)
ax.legend(fontsize=11)
ax.yaxis.set_minor_locator(ticker.AutoMinorLocator())
ax.grid(axis='y', alpha=0.3)
plt.tight_layout()
plt.savefig('fig2_bar_chart.png', dpi=150, bbox_inches='tight')
plt.show()
files.download('fig2_bar_chart.png')

import numpy as np
import matplotlib.pyplot as plt
from scipy.stats import wilcoxon
from statsmodels.stats.multitest import multipletests
from matplotlib.lines import Line2D

# ── Significance test (same as before) ───────────────────────────────────────
ref_resid   = results['Our Model (RF)']['resid']
model_names = [n for n, _ in models]
baselines   = [n for n in model_names if n != 'Our Model (RF)']

raw_pvals = []
for name in baselines:
    diff = results[name]['resid'] - ref_resid
    _, p = wilcoxon(results[name]['resid'], ref_resid, alternative='two-sided') \
           if not np.all(diff == 0) else (None, 1.0)
    raw_pvals.append(p)

_, corrected_pvals, _, _ = multipletests(raw_pvals, method='bonferroni')
pval_map = dict(zip(baselines, corrected_pvals))

def sig_label(p):
    if p < 0.001: return '***'
    if p < 0.01:  return '**'
    if p < 0.05:  return '*'
    return 'ns'

sig_map = {n: sig_label(pval_map[n]) for n in baselines}
sig_map['Our Model (RF)'] = ''

# ── Color & marker per significance ──────────────────────────────────────────
sig_colors = {
    '***': '#d62728',   # red
    '**' : '#ff7f0e',   # orange
    '*'  : '#bcbd22',   # yellow-green
    'ns' : '#aec7e8',   # light blue
    ''   : '#1f77b4',   # blue (reference)
}
sig_sizes = {'***': 180, '**': 160, '*': 140, 'ns': 100, '': 220}

# ── Scatter plot ──────────────────────────────────────────────────────────────
fig, ax = plt.subplots(figsize=(8, 7))

for name in model_names:
    rmse = results[name]['rmse']
    mae  = results[name]['mae']
    sig  = sig_map.get(name, '')

    ax.scatter(rmse, mae,
               color=sig_colors[sig],
               s=sig_sizes[sig],
               edgecolors='white', linewidths=1.2,
               zorder=5)

    # Label each point — offset to avoid overlap
    is_ref = (name == 'Our Model (RF)')
    label  = f"{name}\n{sig}" if sig else name
    ax.annotate(label,
                xy=(rmse, mae),
                xytext=(6, 6), textcoords='offset points',
                fontsize=9,
                fontweight='bold' if is_ref else 'normal',
                color='black' if is_ref else '#333333')

# ── Diagonal reference line (RMSE = MAE, i.e. no large outlier errors) ───────
lims = [
    min(ax.get_xlim()[0], ax.get_ylim()[0]) - 0.005,
    max(ax.get_xlim()[1], ax.get_ylim()[1]) + 0.005,
]
ax.plot(lims, lims, '--', color='grey', linewidth=1.2,
        alpha=0.5, label='RMSE = MAE (no large errors)', zorder=1)

# ── Highlight best quadrant (lower-left) ─────────────────────────────────────
rf_rmse = results['Our Model (RF)']['rmse']
rf_mae  = results['Our Model (RF)']['mae']
ax.axvline(rf_rmse, color='#1f77b4', linestyle=':', alpha=0.4, linewidth=1.2)
ax.axhline(rf_mae,  color='#1f77b4', linestyle=':', alpha=0.4, linewidth=1.2)

# ── Formatting ────────────────────────────────────────────────────────────────
ax.set_xlabel('RMSE  (lower is better →)', fontsize=13)
ax.set_ylabel('MAE  (lower is better →)', fontsize=13)
ax.set_title('RMSE vs MAE — Model Comparison\n'
             'Dot color = significance vs Our Model (RF); '
             'Wilcoxon, Bonferroni-corrected',
             fontsize=11)
ax.tick_params(labelsize=11)
ax.grid(alpha=0.25, linestyle='--')
ax.set_facecolor('#fafafa')

# ── Legend ────────────────────────────────────────────────────────────────────
legend_elements = [
    Line2D([0], [0], marker='o', color='w', markerfacecolor='#1f77b4',
           markersize=12, label='Our Model (RF) — reference'),
    Line2D([0], [0], marker='o', color='w', markerfacecolor='#d62728',
           markersize=11, label='*** p < 0.001'),
    Line2D([0], [0], marker='o', color='w', markerfacecolor='#ff7f0e',
           markersize=10, label='** p < 0.01'),
    Line2D([0], [0], marker='o', color='w', markerfacecolor='#bcbd22',
           markersize=9,  label='* p < 0.05'),
    Line2D([0], [0], marker='o', color='w', markerfacecolor='#aec7e8',
           markersize=9,  label='ns = not significant'),
    Line2D([0], [0], linestyle='--', color='grey', label='RMSE = MAE'),
]
ax.legend(handles=legend_elements, fontsize=9,
          loc='upper left', framealpha=0.95, edgecolor='grey')

plt.tight_layout()
plt.savefig('fig_scatter_rmse_mae.png', dpi=150, bbox_inches='tight')
plt.show()
files.download('fig_scatter_rmse_mae.png')

# ── Figure 3: Residual Distribution Boxplot ───────────────────────────────────
# Ordered bottom-to-top: Our Model (RF) at bottom, Ridge at top (matching reference)
box_order   = list(reversed(model_names))
resid_data  = [results[n]['resid'] for n in box_order]

fig, ax = plt.subplots(figsize=(10, 7))

bp = ax.boxplot(
    resid_data,
    vert=False,
    patch_artist=True,
    showmeans=True,
    labels=box_order,
    boxprops      = dict(facecolor='#C8E6C9', color='black', linewidth=1.2),
    medianprops   = dict(color='black', linewidth=2),
    whiskerprops  = dict(color='black', linewidth=1.2),
    capprops      = dict(color='black', linewidth=1.2),
    flierprops    = dict(marker='o', markerfacecolor='none',
                         markeredgecolor='black', markersize=5, linestyle='none'),
    meanprops     = dict(marker='o', markersize=9,
                         markerfacecolor='red', markeredgecolor='red'),
)

ax.set_xlabel('|Residual|', fontsize=12)
ax.set_title('Residual Distribution Across Models', fontsize=13)
ax.tick_params(axis='y', labelsize=10)
ax.tick_params(axis='x', labelsize=9)
ax.grid(axis='x', alpha=0.3)
plt.tight_layout()
plt.savefig('fig3_residuals.png', dpi=150, bbox_inches='tight')
plt.show()
files.download('fig3_residuals.png')
